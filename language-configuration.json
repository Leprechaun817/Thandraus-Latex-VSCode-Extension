{
	"comments": {
		"lineComment":"%"
	},
	"brackets": [
		["{", "}"],
		["[", "]"],
		["(", ")"]
	],
	"autoClosingPairs": [
		{ "open": "{", "close": "}" },
		{ "open": "[", "close": "]" },
		{ "open": "(", "close": ")" },
		{ "open": "$", "close": "$", "notIn": ["comment", "string"] }
	],
	"surroundingPairs": [
		["{", "}"],
		["[", "]"],
		["(", ")"],
		["$", "$"]
	],
	"folding": {
		"markers": {
			"start": "^\\s*%\\s*#?region\\b",
			"end": "^\\s*%\\s*#?endregion\\b"
		}
	},
	"wordPattern": "(\\\\[A-Za-z@_]+(?::[A-Za-z]+)?)|([A-Za-z@_][A-Za-z0-9@_:-]*)"
}